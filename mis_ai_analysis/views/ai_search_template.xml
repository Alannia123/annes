          .dt-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
}

.dt-bottom .dataTables_paginate {
    order: 1;     /* Left side */
}

.dt-bottom .dataTables_info {
    order: 2;     /* Right side */
}


          .dataTables_paginate .paginate_button {
    padding: 3px 8px;
    border-radius: 6px !important;
    background: #f0f0f0;
    margin: 0 2px;
}

.dataTables_paginate .paginate_button.current {
    background: #714B67 !important;
    color: #fff !important;
}

.dataTables_info {
    font-size: 13px;
    color: #555;
}


