                    border:none;
                    padding:10px 20px;
                    border-radius:8px;
                    font-weight:600;
                    color:#fff;
                    box-shadow:0 3px 8px rgba(0,0,0,0.2);
               ">
                🔍 Back to Search
            </a>

        </t>

        <!-- =============== THINKING MODE ================ -->
