    <link rel="stylesheet" type="text/css" href="/mis_ai_analysis/static/src/css/ai_style.css"/>
    <link rel="stylesheet" type="text/css" href="/mis_ai_analysis/static/src/css/ai_language.css"/>


<div class="o_ai_ama_chat_wrapper">
  <!-- Sidebar -->
  <div class="chat-sidebar">

  <div class="sidebar-header">
    <button class="btn primary" onclick="window.location.href='/web';">⬅ Back to Odoo</button>
    <h4>Search History</h4>
  </div>

  <ul id="chatHistory">
    <t t-foreach="search_history" t-as="history">
      <li onclick="setChatInput(this)">
        <b><t t-esc="history.query_text"/></b>
      </li>
    </t>
  </ul>

</div>


  <!-- Main -->
  <div class="chat-main">
    <div class="chat-header enhanced-chat-header">

    <!-- LEFT -->
    <div class="left-block">
        <button class="o_sidebar_toggle" title="Toggle Sidebar">
            <i class="fa fa-chevron-left"></i>
        </button>

        <span class="welcome-badge">
            Hello <span class="wave-hand">👋</span> Ask me anything!
        </span>
    </div>

    <!-- CENTER -->
    <div class="center-block">
        <span class="ai-badge">
            <span class="ai-icon-bigger animated-ai">🤖</span>
            <span class="ai-title-text animated-text">YOUR AI ASSISTANT!</span>
        </span>
    </div>

    <!-- RIGHT -->
    <div class="right-block">
        <img src="/mis_ai_analysis/static/src/img/ai_search.png"
             class="ai-logo-big"
             alt="AI Logo"></img>
    </div>

</div>




      <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css"/>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>
function loadDataTable() {
    let table = $("#ai_result_table");

    if (table.length &amp;&amp; !$.fn.DataTable.isDataTable(table)) {

        table.DataTable({
            pageLength: 10,
            lengthMenu: [10, 25, 50, 100, 200],
            searching: true,
            ordering: true,
            autoWidth: false,

            scrollX: true,
            scrollY: "480px",
            scrollCollapse: true,

            processing: true,
            deferRender: true,

            // SAFE DOM layout
            dom: "&lt;'dt-top' lf&gt;t&lt;'dt-bottom' ip&gt;",


            drawCallback: function () {
                let api = this.api();
                api.column(0, { page: "current" }).nodes().each(function (cell, i) {
                    cell.innerHTML = i + 1;
                });
            },
        });

        console.log("✔ DataTable Initialized Successfully!");
    }
}


// Observe DOM until table appears
const observer = new MutationObserver(() => {
    if (document.querySelector("#ai_result_table")) {
        loadDataTable();
        observer.disconnect();
    }
});
observer.observe(document.body, { childList: true, subtree: true });
</script>







      <style>

