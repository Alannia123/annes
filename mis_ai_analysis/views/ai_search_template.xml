    <!-- Input -->
    <div class="chat_input">
      <form id="aiForm" action="/ai/search" method="POST" style="display:flex;align-items:center;gap:10px;width:100%;justify-content:center;">
        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
        <div class="search-bar-wrapper">
          <input type="text" id="chatInput" name="chatInput" placeholder="Type your question..."/>
          <button type="button" id="clearBtn" title="Clear">❌</button>
        </div>




        <button type="button" style="cursor: pointer;" id="voiceBtn" title="Click To Start"><i class="fa fa-microphone"></i></button>
        <button type="submit" style="cursor: pointer;" class="btn btn-primary">🔍 Search</button>
      </form>
    </div>
  </div>
