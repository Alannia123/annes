                <!-- AI USER QUERY BOX -->
<div class="ai-query-mini" t-if="result_data">
    <span class="title">AI User Query:</span>
    <span class="text"><b><t t-esc="user_query"/></b></span>
</div>

<!-- AI HOME WELCOME BOX -->
<div class="ai-welcome-mini" t-if="not result_data">
    <span class="welcome-title">Welcome to Your AI Assistant</span>
    <span class="welcome-sub">Ask anything — I’m here to help!</span>
</div>


      <t t-if="result_data">

    <!-- Tabs -->
    <div class="tabs">
      <div class="tab active" onclick="openTab(event, 'preview')">🔹 Result</div>
      <div class="tab" onclick="openTab(event, 'graph')">📊 Graph</div>
      <div class="tab" onclick="openTab(event, 'explanation')">📖 AI Explanation</div>
      <!-- RIGHT SIDE DOWNLOAD BUTTON -->
        <a t-if="download_xlsx_url"
           t-att-href="download_xlsx_url"
           class="download-xlsx-btn">
            ⬇ Download XLSX
        </a>
    </div>

    <div id="preview" class="tab-content active">
          <div class="ai-result-box">

    <!-- Heading -->
    <div class="ai-result-title">📄 AI Result Preview</div>

    <t t-if="result_data">
        <table id="ai_result_table" class="display nowrap" style="width:100%;">

            <thead>
                <tr>
                    <th>Sr.No</th>
                    <t t-foreach="result_data[0].keys()" t-as="header">
                        <th t-attf-style="text-transform: capitalize; #{'text-align: right;' if isinstance(result_data[0][header], (int,float)) else 'text-align: left;'}">
                            <t t-esc="header.replace('_', ' ')"/>
                        </th>
                    </t>
                </tr>
            </thead>

            <tbody>
                <t t-set="count" t-value="0"/>
                <t t-foreach="result_data" t-as="row">
                    <t t-set="count" t-value="count + 1"/>
                    <tr>
                        <td class="row-index"></td>
                        <t t-foreach="result_data[0].keys()" t-as="col">
                            <t t-set="value" t-value="row.get(col)"/>

                            <t t-if="isinstance(value, (int,float))">
                                <td style="text-align: right;">
                                    <t t-esc="'{:,.2f}'.format(value)"/>
                                </td>
                            </t>
                            <t t-else="">
                                <td><t t-esc="value or ''"/></td>
                            </t>
                        </t>
                    </tr>
                </t>
            </tbody>
        </table>
    </t>

    <t t-else="">
        <div class="ai-result-empty">No results found.</div>
    </t>

</div>

</div>


    <div id="graph" t-attf-class="tab-content #{'active' if active_tab=='graph' else ''}">
        <div class="ai-graph-box mb-3" role="alert">
            <t t-if="chart_data">
                <div id="bar_chart" style="width:100%; height:420px;"></div>
            </t>
            <t t-if="not chart_data">
                <p>No chart data available for this result.</p>
            </t>
        </div>
    </div>






<!--                    &lt;!&ndash; Expose chart_data to JS as a global variable safely &ndash;&gt;-->
                    <t t-jquery="body" t-operation="append">
                        <script type="text/javascript">
                            window.AI_CHART_DATA = <t t-raw="json.dumps(chart_data or {})"/>;
                        </script>
                    </t>

                    <!-- Plotly CDN (fast) -->
                    <script src="https://cdn.plot.ly/plotly-latest.min.js"></script>

                <!-- Include module static JS (registered in manifest assets) -->
                    <script type="text/javascript" src="/mis_ai_analysis/static/src/js/ai_chart.js"></script>

    <div id="explanation" class="tab-content">

    <!-- If explanation exists -->
    <t t-if="ai_explanation_html">
        <div class="ai-explanation-heading">🧠 AI Explanation</div>
        <div id="aiExplanationContent" class="ai-explanation-box" t-raw="ai_explanation_html"/>
    </t>
    <t t-if="not ai_explanation_html">
        <div class="ai-explanation-box ai-no-explain">
            <strong>⚠ Explanation Not Available</strong>
            <div>
                The data is too large or complex for AI to generate an explanation.
                Please refine your query for a more focused result.
            </div>
        </div>
    </t>

</div>

