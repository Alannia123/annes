<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Kanban view of Education Student-->
    <record id="education_student_view_kanban" model="ir.ui.view">
        <field name="name">education.student.view.kanban</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="last_name"/>
<!--                <field name="guardian_id"/>-->
                <field name="class_division_id"/>
                <field name="city"/>
                <field name="mobile"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_res_partner_kanban">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('education.student', 'image_1920', record.id.raw_value)"
                                     alt="Image"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title oe_partner_heading">
                                    <field name="name"
                                           style="margin-right: 5px"/>
                                    <field name="last_name"/>
                                </strong>
                                <div class="o_kanban_tags_section oe_kanban_partner_categories"/>
                                <ul>
                                    <li t-if="record.class_division_id.raw_value">
                                        Class :
                                        <field name="class_division_id"/>
                                    </li>
<!--                                    <li t-if="record.guardian_id.raw_value">-->
<!--                                        Parent :-->
<!--                                        <field name="guardian_id"/>-->
<!--                                    </li>-->
                                    <li t-if="record.mobile.raw_value">
                                        <i class="fa fa-phone" title="Phone"/>
                                        <field name="mobile"/>
                                    </li>
                                    <li t-if="record.email.raw_value">
                                        <i class="fa fa-envelope" title="Email"/>
                                        <a t-attf-href="mailto:#{record.email.value}">
                                            <field name="email"/>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!--Tree view of Education Student-->
    <record id="education_student_view_tree" model="ir.ui.view">
        <field name="name">education.student.view.tree</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <tree string="Student">
                <field name="register_no"/>
                <field name="name"/>
                <field name="last_name"/>
                <field name="roll_no"/>
                <field name="class_division_id"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="blood_group"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="no_of_discipline_history" groups="mis_education_core.group_education_principal"/>
                <field name="hide_result" groups="mis_education_core.group_education_principal" widget="boolean_toggle"/>
                <field name="promoted" groups="mis_education_core.group_education_principal" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!--Form view of Education Student-->
    <record id="education_student_view_form" model="ir.ui.view">
        <field name="name">education.student.view.form</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                        <button name="tc_issue_reason_wizard" string="TC Issue" invisible="tc_issued or drop_out" type="object" class="oe_highlight"/>
                        <button name="dropout_reason_wizard" string="Student Dropout" invisible="tc_issued or drop_out" type="object" class="oe_highlight"/>
                </header>
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_student_documents" type="object"
                                widget="statinfo"
                                class="oe_stat_button" icon="fa-calendar"
                                string="Documents"/>
                        <button type="object" name="action_view_student_discipline_history" class="oe_stat_button"
									string="Discipline" invisible="no_of_discipline_history == 0" icon="fa-ban" groups="mis_education_core.group_education_principal">
								<field name="no_of_discipline_history" widget="statinfo" string="Discipline"/>
                        </button>
                    </div>

                    <div class="student-header row align-items-center">

    <!-- LEFT SIDE : NAME SECTION -->
    <div class="col-12 col-md-8 student-name-section text-center text-md-start">

        <h3 class="student-adno">
            <field name="ad_no" invisible="ad_no == False"/>
        </h3>

        <h1 class="student-fullname">
            <field name="name"
                   placeholder="First Name"
                   required="1"
                   class="me-2"/>

            <field name="last_name"
                   placeholder="Last Name"
                   required="1"/>
        </h1>

    </div>

    <!-- RIGHT SIDE : PHOTO SECTION -->
    <div class="col-12 col-md-4 student-avatar-wrapper text-center mt-3 mt-md-0">

        <field name="image_1920"
               widget="image"
               class="student-avatar"
               options="{'preview_image': 'image_128'}"/>

        <div class="mt-2">
            <button name="action_open_camera"
                    type="object"
                    class="btn btn-outline-primary btn-sm w-100 w-md-auto">
                <i class="fa fa-camera me-1"/>
                Capture Image
            </button>
        </div>

    </div>

</div>
<!--                    <separator/>-->

                    <group col="3">
                        <group>
                            <field name="ad_no" invisible="1"/>
                            <field name="register_no" placeholder="Student Register Number" required="1" readonly="1"/>
                            <field name="student_new_old" readonly="1"/>
                            <field name="no_of_discipline_history" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="admission_class_id" invisible="1"/>
                            <field name="class_division_id" required="1"/>
                            <field name="roll_no" placeholder="Student Roll Number" required="1"/>
                        </group>
                        <group invisible="not tc_issued">
                            <field name="tc_issued"  widget="boolean_button"/>
                            <field name="tc_issue_reason_id"   readonly="1"/>
                        </group>
                        <group invisible="not drop_out">
                            <field name="drop_out"  widget="boolean_button"/>
                            <field name="drop_out_reason_id"  readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="student_html_compute" invisible="1"/>
<!--                        <div>-->
                            <field name="student_html" widget="html" readonly="1" no_label="1" groups="mis_education_core.group_education_principal"/>
<!--                        </div>-->
                    </group>
                    <notebook>
                        <page string="Student Details">
<!--                            <separator string="Basic Details"/>-->
                            <group >
                                <group>
                                    <field name="sec_lang_id"/>
                                </group>
                                <group>
                                    <field name="medium_id"/>
                                </group>
                            </group>
                            <separator string="Student Info"/>
                            <group>
                                <group>
                                    <field name="mother_tongue"/>
                                    <field name="gender"/>
<!--                                    <field name="guardian_id" invisible="1"/>-->
                                    <field name="religion"/>
                                    <field name="father_name"/>
                                    <field name="father_qualify"/>
                                    <field name="father_occupation"/>
                                </group>
                                <group>
                                    <field name="date_of_birth"/>
                                    <field name="aadhar_no"/>
                                    <field name="date_of_addmission"/>
                                    <field name="blood_group"/>
                                    <field name="caste"/>
                                    <field name="mother_name"/>
                                    <field name="mother_qualify"/>
                                    <field name="mother_occupation"/>
                                </group>
                            </group>
                            <group name="amenity_info">
                            </group>
                            <separator string="Contact Info"/>
                            <group>
                                <group groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin">
                                    <field name="email" />
                                    <field name="user_id" readonly="1" options='{"no_open": True, "no_create": True}'/>
                                    <field name="login" readonly="1"/>
                                    <field name="ch_password" password="0"/>
                                    <button name="update_password" icon="fa-refresh" string="Update" type="object"/>
                                </group>
                                <group>
                                    <field name="mobile" required="1" string="Mobile(WhatsApp)"/>
                                    <field name="phone" required="0" string="Alternate Number"/>
                                </group>
                            </group>
                            <group>
                                <group string="Contact Address">
                                    <span class="o_form_label o_td_label"
                                          name="address_name">
                                        <b>Address</b>
                                    </span>
                                    <div class="o_address_format">
                                        <field name="street" required="1"
                                               placeholder="Street..."
                                               class="o_address_street"/>
                                        <field name="street2"
                                               placeholder="Street 2..."
                                               class="o_address_street"/>
                                        <field name="city" placeholder="City"
                                               class="o_address_city"/>
                                        <field name="state_id"
                                               class="o_address_state"
                                               placeholder="State"
                                               options='{"no_open": True}'/>
                                        <field name="zip" placeholder="ZIP"
                                               class="o_address_zip"/>
                                        <field name="country_id"
                                               placeholder="Country"
                                               class="o_address_country"
                                               options='{"no_open": True, "no_create": True}'/>
                                    </div>
                                    <field name="is_same_address"/>
                                </group>
                                <group string="Permanent Address"
                                       invisible="is_same_address == True">
                                    <span class="o_form_label o_td_label"
                                          name="address_name">
                                        <b>Permanent Address</b>
                                    </span>
                                    <div class="o_address_format">
                                        <field name="per_street"
                                               placeholder="Street..."
                                               class="o_address_street"/>
                                        <field name="per_street2"
                                               placeholder="Street 2..."
                                               class="o_address_street"/>
                                        <field name="per_city"
                                               placeholder="City"
                                               class="o_address_city"/>
                                        <field name="per_state_id"
                                               class="o_address_state"
                                               placeholder="State"
                                               options='{"no_open": True}'/>
                                        <field name="per_zip"
                                               placeholder="ZIP"
                                               class="o_address_zip"/>
                                        <field name="per_country_id"
                                               placeholder="Country"
                                               class="o_address_country"
                                               options='{"no_open": True, "no_create": True}'/>
                                    </div>
                                </group>
                            </group>
                            <group>
                        <field name="exist_sis_bro_info" readonly="1"/>
                    </group>
                    <group col="3" name="extra_info" string="Extra Info" invisible="exist_sis_bro_info == False">
                        <group>
                            <field name="exist_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="exist_class" readonly="1"/>
                        </group>
                        <group>
                            <field name="exist_section" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="special_concern" readonly="1"/>
                    </group>
                        </page>
                        <page string="Class History">
                            <field name="class_history_ids">
                                <tree editable="bottom">
                                    <field name="class_id" required="1"/>
                                    <field name="academic_year_id"
                                           required="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <!--Search view of Education Student-->
    <record id="education_student_search" model="ir.ui.view">
        <field name="name">Students</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <search string="Search Students">
                <field name="name" string="Student Name"/>
                <field name="register_no" string="Register No"/>
                <field name="class_division_id"/>
<!--                <field name="medium_id"/>-->
                <field name="sec_lang_id"/>
<!--                <field name="gender"/>-->
<!--                <field name="religion"/>-->
<!--                <field name="caste"/>-->
<!--                <field name="mother_tongue"/>-->
                <group expand='0' string='Group by...'>
                    <filter string='Division' name="class" domain="[]"
                            context="{'group_by' : 'class_division_id'}"/>
                    <filter string='Gender' name="gender" domain="[]"
                            context="{'group_by' : 'gender'}"/>
<!--                    <filter string='Medium' name="medium" domain="[]"-->
<!--                            context="{'group_by' : 'medium_id'}"/>-->
<!--                    <filter string='Religion' name="religion" domain="[]"-->
<!--                            context="{'group_by' : 'religion'}"/>-->
<!--                    <filter string='Caste' name="caste" domain="[]"-->
<!--                            context="{'group_by' : 'caste'}"/>-->
<!--                    <filter string='Mother Tongue' name="language" domain="[]"-->
<!--                            context="{'group_by' : 'mother_tongue'}"/>-->
                </group>
            </search>
        </field>
    </record>

    <!--Action of Education Student-->
    <record id="education_student_action" model="ir.actions.act_window">
        <field name="name">Student</field>
        <field name="res_model">education.student</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="education_student_search"/>
        <field name="context">{'search_default_class': 1, 'create': True}</field>
        <field name="domain">[('tc_issued', '=', False), ('drop_out', '=', False)]</field>

        <!-- Force first view -->
        <field name="view_id" ref="mis_education_core.education_student_view_tree"/>

        <field name="views" eval="[
            (ref('mis_education_core.education_student_view_tree'), 'tree'),
            (ref('mis_education_core.education_student_view_form'), 'form')
        ]"/>
    </record>



    <record id="education_student_tc_drop_search" model="ir.ui.view">
        <field name="name">education.student.search</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <search>

                <filter name="filter_tc_issued"
                        string="TC Issued"
                        domain="[('tc_issued','=',True)]"/>

                <filter name="filter_drop_out"
                        string="Drop Out"
                        domain="[('drop_out','=',True)]"/>

            </search>
        </field>
    </record>

    <!--Action of Education Student TC Issued-->
    <record id="education_student_tc_issued_action" model="ir.actions.act_window">
        <field name="name">Student</field>
        <field name="res_model">education.student</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="education_student_tc_drop_search"/>
        <field name="context">{'search_default_class': 1, 'create': False}</field>
        <field name="domain">
            ['|', ('tc_issued', '=', True), ('drop_out', '=', True)]
        </field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create your first student here.
            </p>
        </field>
    </record>




            <!-- Server Action: Issue TC -->
        <record id="action_issue_tc_server" model="ir.actions.server">
            <field name="name">Issue TC</field>
            <field name="model_id" ref="model_education_student"/>
            <field name="binding_model_id" ref="model_education_student"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
        action = {
            'type': 'ir.actions.act_window',
            'name': 'Issue TC',
            'res_model': 'tc.issue.reason',
            'view_mode': 'form',
            'target': 'new',
            'context': {
                'active_ids': records.ids,
            }
        }
            </field>
        </record>

<!--    <menuitem id="education_student_menu" name="Student" sequence="10"-->
<!--              parent="menu_education_admission"-->
<!--              action="education_student_action"/>-->

    <menuitem id="education_student_root_menu" name="Student Information" sequence="10"
                web_icon="mis_education_core,static/description/stu_nfo.png"
             groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin" action="education_student_action"/>
    <menuitem id="education_student_tc_root_menu" name="TC &amp; Dropouts" sequence="10"
                web_icon="mis_education_core,static/description/tc.png"
             groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin" action="education_student_tc_issued_action"/>



</odoo>
