<?xml version="1.0" encoding="utf-8"?>
<odoo>



    <record id="education_student_class_teachers_view_tree" model="ir.ui.view">
        <field name="name">education.student.class.view.tree</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <tree string="Student">
                <field name="register_no"/>
                <field name="name"/>
                <field name="last_name"/>
                <field name="roll_no"/>
                <field name="class_division_id"/>
                <field name="street"/>
                <field name="city"/>
                <field name="mobile"/>
                <field name="phone"/>
            </tree>
        </field>
    </record>


     <!--Form view of Education Student-->
    <record id="education_student_class_teachers_view_form" model="ir.ui.view">
        <field name="name">education.student.class.view.form</field>
        <field name="model">education.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <div class="student-header row align-items-center">
                        <!-- LEFT SIDE : NAME SECTION -->
                        <div class="col-12 col-md-8 student-name-section text-center text-md-start">
                            <h3 class="student-adno">
                                <field name="ad_no" invisible="ad_no == False"/>
                            </h3>
                            <h1 class="student-fullname">
                                <field name="name"     readonly="1"     class="me-2"/>
                                <field name="last_name"  readonly="1"/>
                            </h1>
                        </div>
                        <div class="col-12 col-md-4 student-avatar-wrapper text-center mt-3 mt-md-0">
                            <field name="image_1920"     readonly="1"            widget="image"         class="student-avatar"       options="{'preview_image': 'image_128'}"/>
                        </div>
                    </div>
                    <group>
                        <group>
                             <field name="roll_no" readonly="1" />
                                <field name="class_division_id" readonly="1" />
                        </group>
                        <group>
                            <field name="street" readonly="1" />
                            <field name="city" readonly="1" />
                            <field name="mobile" readonly="1" />
                            <field name="phone" readonly="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>






            <record id="education_student_teacher_division_action" model="ir.actions.act_window">
                <field name="name">Student</field>
                <field name="res_model">education.student</field>
                <field name="view_mode">tree,form</field>
<!--                <field name="search_view_id" ref="education_student_search"/>-->
<!--                <field name="context">{'search_default_class': 1, 'create': False}</field>-->
                <field name="domain">[('tc_issued', '=', False), ('drop_out', '=', False)]</field>

                <!-- Force first view -->
                <field name="view_id" ref="mis_education_core.education_student_class_teachers_view_tree"/>

                <field name="views" eval="[
                    (ref('mis_education_core.education_student_class_teachers_view_tree'), 'tree'),
                    (ref('mis_education_core.education_student_class_teachers_view_form'), 'form')
                ]"/>
            </record>




        <menuitem id="education_student_class_root_menu" name="Students ID" sequence="30"
                web_icon="mis_education_core,static/description/teacher_id.png"
              action="education_student_teacher_division_action"/>


</odoo>