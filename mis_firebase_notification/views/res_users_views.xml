<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_fcm" model="ir.ui.view">
        <field name="name">res.users.form.inherit.fcm</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="FCM Tokens">
                    <group>
                        <field name="fcm_token_count" readonly="1"/>
<!--                        <field name="fcm_token" readonly="1"/>-->
                    </group>
                    <field name="fcm_token_ids" nolabel="1">
                        <tree>
                            <field name="last_seen"/>
                            <field name="os"/>
                            <field name="device_name"/>
                            <field name="token"/>
                            <field name="active"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
