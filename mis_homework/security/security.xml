<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
 <!-- Principal & Office Admin: See all records -->
    <record id="student_homework_rule_admin" model="ir.rule">
        <field name="name">student.homework - all access (principal/admin)</field>
        <field name="model_id" ref="model_student_homework"/>
        <field name="groups" eval="[(4, ref('mis_education_core.group_education_principal')),
                                    (4, ref('mis_education_core.group_education_office_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- Faculty: Only own records -->
    <record id="student_homework_rule_faculty" model="ir.rule">
        <field name="name">student.homework - own records (faculty)</field>
        <field name="model_id" ref="model_student_homework"/>
        <field name="groups" eval="[(4, ref('mis_education_core.group_education_faculty'))]"/>
        <field name="domain_force">[('faculty_user_id', '=', user.id)]</field>
    </record>


         <record id="all_homework_to_admin" model="ir.rule">
            <field name="name">All Homeworks Attendance Admin</field>
            <field ref="model_student_homework_line" name="model_id"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('mis_education_core.group_education_principal'))]"/>
        </record>


        <record id="student_homework_rule_faculty" model="ir.rule">
            <field name="name">student.homework.line - faculty access</field>
            <field name="model_id" ref="model_student_homework_line"/>
            <field name="groups" eval="[(4, ref('mis_education_core.group_education_faculty'))]"/>
            <field name="domain_force">
                ['|', ('faculty_user_id', '=', user.id), ('uploaded_by', '=', user.id)]
            </field>
        </record>


    </data>
</odoo>
