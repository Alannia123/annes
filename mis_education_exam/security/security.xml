<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


         <record id="all_marks_entyr_to_admin" model="ir.rule">
            <field name="name">All Exam Entries Admin</field>
            <field name="model_id" ref="model_education_exam_valuation"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('mis_education_core.group_education_principal')),
                                        (4, ref('mis_education_core.group_education_office_admin'))]"/>
        </record>



        <record id="teachers_clas_subject_mark_entries" model="ir.rule">
            <field name="name">Teachers Class Marks</field>
            <field name="model_id" ref="model_education_exam_valuation"/>
            <field name="domain_force">
                [('faculty_ids.user_id', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('mis_education_core.group_education_faculty'))]"/>
        </record>


         <record id="all_evaluation_to_admin" model="ir.rule">
            <field name="name">All Student Evaluation Admin</field>
            <field name="model_id" ref="model_education_evaluation"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('mis_education_core.group_education_principal')),
                                        (4, ref('mis_education_core.group_education_office_admin'))]"/>
        </record>


        <record id="teachers_evaluation_to_admin" model="ir.rule">
            <field name="name">Faculty Student Evaluation Admin</field>
            <field name="model_id" ref="model_education_evaluation"/>
            <field name="domain_force">
                [('faculty_id.user_id', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('mis_education_core.group_education_faculty'))]"/>
        </record>



    </data>
</odoo>
