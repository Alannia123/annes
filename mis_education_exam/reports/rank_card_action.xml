<?xml version="1.0" encoding="utf-8"?>
<odoo>


<!--    Paper Format-->
    <record id="paperformat_a4_landscape" model="report.paperformat">
    <field name="name">A4 Landscape</field>
    <field name="default" eval="False"/>
    <field name="format">A4</field>
    <field name="orientation">Landscape</field>
    <field name="margin_top">2</field>
    <field name="margin_bottom">10</field>
    <field name="margin_left">10</field>
    <field name="margin_right">2</field>
</record>

    <record id="paperformat_veena_marksheet" model="report.paperformat">
        <field name="name">Veena Invoice A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
    <!--    <field name="report_ids" eval="[(6, 0, [ref('account.account_invoices_without_payment'), ref('account.account_invoices')])]"/>-->
        <field name="dpi">100</field>
    </record>



    <!--Report action of Rank card-->
    <record id="action_generate_rank_card" model="ir.actions.report">
        <field name="name">Class Rank Card</field>
        <field name="model">education.class.division</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mis_education_exam.report_rank_card_template</field>
        <field name="report_file">mis_education_exam.report_rank_card_template</field>
        <field name="print_report_name">'Rank Card - %s' % (object.name)</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_a4_landscape"/>
        <field name="binding_model_id" ref="mis_education_core.model_education_class_division"/>
    </record>


    <!--Report action of Rank card-->
    <record id="exam_marksheet_pdf" model="ir.actions.report">
        <field name="name">Class Marksheet</field>
        <field name="model">education.class.division</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">mis_education_exam.exam_marksheet_template</field>
        <field name="report_file">mis_education_exam.exam_marksheet_template</field>
        <field name="print_report_name">'Marksheet - %s' % (object.name)</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_veena_marksheet"/>
        <field name="binding_model_id" ref="mis_education_core.model_education_class_division"/>
    </record>


    <!--Report action of Sub marksheet record card-->
    <record id="exam_subject_marksheet_pdf" model="ir.actions.report">
        <field name="name">Subject Marksheet</field>
        <field name="model">education.exam.valuation</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">mis_education_exam.exam_subject_marksheet_template</field>
        <field name="report_file">mis_education_exam.exam_subject_marksheet_template</field>
        <field name="print_report_name">'Marksheet - %s' % (object.name)</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_veena_marksheet"/>
        <field name="binding_model_id" ref="mis_education_exam.model_education_exam_valuation"/>
    </record>

</odoo>
