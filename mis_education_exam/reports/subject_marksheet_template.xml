<odoo>
    <template id="exam_subject_marksheet_template_document">
        <t t-call="web.basic_layout">
            <div class="page">
              <h3 ><span style="background-color: #b3b3cc; padding: 5px; border-radius: 4px;">Marksheet - <t t-esc="doc.name"/> - <t t-esc="doc.subject_id.name"/></span>
                  <span style="background-color: ##ccccb3;padding-left: 40px;border-radius: 10px;">Academic Year : <t t-esc="doc.exam_id.academic_year_id.name"/></span></h3>
                <style>
                        .vertical-header-row th {
                            height: 150px;

                            vertical-align: bottom !important;
                            text-align: center;
                            padding-bottom: 25px;
                        }

                        .vertical-header-row th .vertical-text {
                            transform: rotate(-90deg);
                            -webkit-transform: rotate(-90deg); /* Crucial for wkhtmltopdf */
                            width: 60px;
                            white-space: nowrap;
                            display: inline-block;
                        }

                                            table, th, td {
                                                border: 1px solid black;
                                                border-collapse: collapse;
                                            }

                                            @media print {
                            thead.vertical-header-row {
                                display: table-row-group !important;
                            }
                        }
                </style>
                <table style="width: 100%; table-layout: fixed; border-collapse: collapse;">
                    <thead >
                        <tr>
                            <th rowspan="2" style="background-color: #ffe6b3;width:4%;">Sr.No</th>
                            <th rowspan="2" style="background-color: #ffe6b3;width:5%;">Roll NO</th>
                            <th rowspan="2" style="background-color: #ffe6b3;width:20%;width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Student Name</th>
                            <th colspan="3" style="background-color: #ffe6b3;width:50%;"><t t-esc="doc.subject_id.name"/></th>
                        </tr>
                        <tr>
                            <th style="background-color: #ffbb99;width:4%;">Exam Mark</th>
                            <th style="background-color: #ffbb99;width:5%;">Assign Mark</th>
                            <th style="background-color: #ffbb99;width:50%;">Total Mark</th>
                        </tr>
                    </thead>
                    <t t-set="count" t-value="0"/>
                    <t t-foreach="doc.valuation_line_ids" t-as="exam_line">
                        <tbody>
                            <tr>
                                <t t-set="sl_no" t-value="count + 1"/>
                                <td style="text-align: center;"><t t-esc="sl_no"/> </td>
                                <td style="text-align: center;"><t t-esc="exam_line.student_id.roll_no"/> </td>
                                <td style="background-color: #e6f9ff;"><t t-esc="exam_line.student_name"/> </td>
                                <t t-if="exam_line.exam_mark == 0">
                                    <td style="text-align: center;background-color: #f9ecf2;" > - </td>
                                </t>
                                <t t-else="">
                                    <td style="text-align: center;background-color: #f9ecf2;" >
                                        <t t-esc="int(exam_line.exam_mark)" />
                                    </td>
                                </t>
                                <t t-if="exam_line.assign_mark == 0">
                                    <td style="text-align: center;background-color: #f2ffe6;" > - </td>
                                </t>
                                <t t-else="">
                                    <td style="text-align: center;background-color: #f2ffe6;" >
                                        <t t-esc="int(exam_line.assign_mark)" />
                                    </td>
                                </t>
                                <t t-if="exam_line.mark_scored == 0">
                                    <td style="text-align: center;" > - </td>
                                </t>
                                <t t-elif="exam_line.mark_scored &lt; doc.pass_mark">
                                    <td style="text-align: center;color: red;" >
                                        <t t-esc="int(exam_line.mark_scored)" />
                                    </td>
                                </t>
                                <t t-else="">
                                    <td style="text-align: center; color: green;" >
                                        <t t-esc="int(exam_line.mark_scored)" />
                                    </td>
                                </t>
                            </tr>
                        </tbody>
                        <t t-set="count" t-value="count + 1"/>
                    </t>
                </table>
            </div>
          </t>
    </template>



        <template id="exam_subject_marksheet_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="mis_education_exam.exam_subject_marksheet_template_document" />
                </t>
            </t>
        </template>
</odoo>
