<odoo>
    <template id="exam_marksheet_template_document">
        <t t-call="web.basic_layout">
            <div class="page">
                <t t-set="marksheet_exam" t-value="doc.get_current_exam()"/>
                <t t-set="exam_lines" t-value="doc.get_current_exam_lines(marksheet_exam)"/>
              <h3 style="background-color: #b3b3cc; padding: 5px; border-radius: 4px;">Marksheet - <t t-esc="doc.name"/> (<t t-esc="marksheet_exam.name"/>)</h3>
                <style>
.vertical-header-row th {
    height: 150px;

    vertical-align: bottom !important;
    text-align: center;
    padding-bottom: 25px;
}

.vertical-header-row th .vertical-text {
    transform: rotate(-90deg);
    -webkit-transform: rotate(-90deg); /* Crucial for wkhtmltopdf */
    width: 60px;
    white-space: nowrap;
    display: inline-block;
}

                    table, th, td {
                        border: 1px solid black;
                        border-collapse: collapse;
                    }

                    @media print {
    thead.vertical-header-row {
        display: table-row-group !important;
    }
}
<!--                    th {-->
<!--                        height: 150px;-->
<!--                        width: 30px;-->
<!--                        text-align: center;-->
<!--                        vertical-align: middle;-->
<!--                        padding: 0;-->
<!--                    }-->

                </style>
                <table style="width: 100%; table-layout: fixed; border-collapse: collapse;">
                    <thead class="vertical-header-row">
                        <tr>
                            <th style="background-color: #ffe6b3;width:4%;"><div class="vertical-text">Sr.No</div></th>
                            <th style="background-color: #ffe6b3;width:5%;"><div class="vertical-text">Roll NO</div></th>
<!--                            <th style="background-color: #ffe6b3;width:8%;"><div class="vertical-text">Division</div></th>-->
                            <th style="background-color: #ffe6b3;width:20%;width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><div class="vertical-text">Student Name</div></th>
<!--                            <th style="background-color: #ffe6b3;"><div class="vertical-text">Last Name</div></th>-->
                            <t t-foreach="marksheet_exam.subject_line_ids" t-as="subject">
                                <th style="background-color: #ffbb99;">
                                    <div class="vertical-text">
                                        <t t-esc="subject.subject_id.name"/>
                                    </div>
                                </th>
                            </t>
                            <th style="background-color: #b3c6ff;width:10%;"><div class="vertical-text">Total</div></th>
                            <th style="background-color: #b3ffb3;width:10%;"><div class="vertical-text">Percentage</div></th>
                        </tr>
                    </thead>
                    <t t-set="sub_len" t-value="len(marksheet_exam.subject_line_ids)"/>
                    <t t-set="stu_len" t-value="len(exam_lines)"/>
                    <t t-set="count" t-value="0"/>
                    <t t-foreach="exam_lines" t-as="exam">
                        <tbody>
                            <tr>
                                <t t-set="sl_no" t-value="count + 1"/>
                                <td style="text-align: center;"><t t-esc="sl_no"/> </td>
                                <td style="text-align: center;"><t t-esc="exam_lines[count].student_id.roll_no"/> </td>
<!--                                <td style="text-align: center;"><t t-esc="exam_lines[0].division_id.name"/> </td>-->
                                <td ><t t-esc="exam_lines[count].student_id.name"/> </td>
<!--                                <td ><t t-esc="exam_lines[count].student_id.last_name"/> </td>-->

                                <t t-foreach="marksheet_exam.subject_line_ids" t-as="lis_subject">
                                    <t t-set="line_subject" t-value="exam_lines[count].subject_line_ids.filtered(lambda line: line.subject_id.id == lis_subject.subject_id.id)"/>
                                    <t t-if="line_subject">
                                        <t t-if="line_subject.mark_scored == 0">
                                            <td style="text-align: center;" > -
<!--                                                <t t-esc="int(line_subject.mark_scored)" />-->
                                            </td>
                                        </t>
                                        <t t-elif="line_subject.mark_scored &lt; line_subject.pass_mark">
                                            <td style="text-align: center;color: red;" >
                                                <t t-esc="int(line_subject.mark_scored)" />
                                            </td>
                                        </t>
                                        <t t-else="">
                                            <td style="text-align: center; color: green;" >
                                                <t t-esc="int(line_subject.mark_scored)" />
                                            </td>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <td style="text-align: center;" > - </td>
                                    </t>
                                </t>
                                <td style="text-align: center;"><t t-esc="int(exam_lines[count].total_mark_scored)"/> </td>
                                <td style="text-align: center;"><t t-esc="round((exam_lines[count].total_mark_percentage), 2)"/> </td>
                            </tr>
                        </tbody>
                        <t t-set="count" t-value="count + 1"/>
                    </t>
                </table>
            </div>
          </t>
    </template>



        <template id="exam_marksheet_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="mis_education_exam.exam_marksheet_template_document" />
                </t>
            </t>
        </template>
</odoo>
