<?xml version="1.0" encoding="utf-8"?>
<odoo>


<!--    Paper Format-->
    <record id="paperformat_a4_landscape_student" model="report.paperformat">
        <field name="name">A4 Landscape</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
    </record>



    <!--Report action of Rank card-->
    <record id="action_generate_rank_student_card" model="ir.actions.report">
        <field name="name">Student Rank Card</field>
        <field name="model">education.student</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">mis_education_exam.report_student_rank_card_template</field>
        <field name="report_file">mis_education_exam.report_student_rank_card_template</field>
        <field name="print_report_name">'Rank Card - %s' % (object.name)</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_a4_landscape_student"/>
        <field name="binding_model_id" ref="mis_education_core.model_education_student"/>
    </record>



</odoo>
