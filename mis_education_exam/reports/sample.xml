                        <style>
                    @page {
                        size: A4 landscape;
                        margin: 15mm 10mm 10mm 10mm;  /* increased top margin for downward shift */
                    }

                    body {
                        font-size: 13px;   /* increased from 10–11px */
                        zoom: 1.10;        /* slightly enlarges everything */
                    }

                    .page {
                        width: 100%;
                        height: 100%;
                        padding-top: 10mm; /* extra internal top padding */
                        page-break-after: always !important;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                        table-layout: fixed;
                        font-size: 11px;   /* slightly larger table text */
                    }

                    th, td {
                        padding: 4px 6px !important;
                        word-wrap: break-word;
                    }

                    h1, h2, h3 {
                        margin: 3px 0;
                        font-weight: 600;
                    }

                    h2 {
                        font-size: 16px;
                        text-align: center;
                    }

                    h3 {
                        font-size: 14px;
                        text-align: center;
                    }

                    .page-break {
                        page-break-after: always;
                    }
                </style>


