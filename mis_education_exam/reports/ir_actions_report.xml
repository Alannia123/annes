<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Setting the paper format -->
    <!-- Optional: precise A4 paper format with tight margins -->
    <record id="paperformat_admit_a4" model="report.paperformat">
        <field name="name">Admit A4 Tight</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>


    <!--Generate the pdf report-->
    <record id="action_admit_card_print_report" model="ir.actions.report">
        <field name="name">Print Admit Card</field>
        <field name="model">education.exam</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">mis_education_exam.report_print_admit_card_report</field>
        <field name="report_file">mis_education_exam.report_print_admit_card_report</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_admit_a4"/>
<!--        <field name="binding_model_id" ref="model_education_exam"/>-->
        <field name="binding_type">report</field>
    </record>

    <!--Generate the Admit card Division-->
    <record id="action_admit_card_print_division" model="ir.actions.report">
        <field name="name">Division Admit Card</field>
        <field name="model">education.exam</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mis_education_exam.admit_card_division</field>
        <field name="report_file">mis_education_exam.admit_card_division</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_admit_a4"/>
        <field name="binding_model_id" ref="model_education_exam"/>
        <field name="binding_type">report</field>
    </record>

    <!--Generate the Admit card Student-->
    <record id="action_admit_card_print_student" model="ir.actions.report">
        <field name="name">Student Admit Card</field>
        <field name="model">education.exam</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mis_education_exam.admit_card_student_report</field>
        <field name="report_file">mis_education_exam.admit_card_student_report</field>
        <field name="paperformat_id" ref="mis_education_exam.paperformat_admit_a4"/>
        <field name="binding_model_id" ref="model_education_exam"/>
        <field name="binding_type">report</field>
    </record>


</odoo>
