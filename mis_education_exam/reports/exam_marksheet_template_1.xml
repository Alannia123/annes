    table, th, td {
        border: 1px solid black;
        border-collapse: collapse;
    }
    th {
        height: 150px;
        width: 30px;
        text-align: center;
        vertical-align: middle;
        padding: 0;
    }
    .vertical-text {
        display: block;
        transform: rotate(-90deg);
        transform-origin: center center;
        white-space: nowrap;
        width: 0px; /* Helps centering in PDF */
    }
</style>

