<?xml version="1.0" encoding="utf-8" ?>
<odoo>

        <record id="monthly_attendance_report" model="ir.actions.report">
            <field name="name">Monthly Attendance report</field>
            <field name="model">monthly.attendance.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">mis_education_attendances.monthly_attendance_report_temp</field>
        </record>


        <template id="monthly_attendance_report_temp">
            <t t-call="web.html_container">
                <t t-call-assets="web.report_assets_common"/> <!-- ✅ ensures FontAwesome loads in PDF -->
                <t t-call-assets="web.report_assets_pdf"/>     <!-- ✅ ensures PDF-specific CSS/JS -->

                <div class="page">
                    <h2 style="text-align:center;color:blue;">
                        Monthly Attendance Report
                    </h2>

                    <table width="100%">
                        <tr>
                            <td class="text-center" width="25%"><b>Division</b>: <t t-esc="standard_name"/></td>
                            <td class="text-center" width="25%"><b>Month</b>: <t t-esc="month_str"/></td>
                            <td class="text-center" width="25%"><b>Academic Year</b>: <t t-esc="academic_year_id"/></td>
                            <td class="text-center" width="25%"><b>Total Days</b>: <t t-esc="total_days"/></td>
                        </tr>
                    </table>

                    <table class="table table-bordered" style="font-size:13px; width:100%;">
                        <thead>
                            <tr>
                                <th style="width:150px;text-align: start">Student Name</th>
                                <th style="width:40px;text-align: start">Roll No</th>
                                <t t-foreach="dates" t-as="d">
                                    <th style="width:18px;"><t t-esc="d.strftime('%d')"/></th>
                                </t>
                                <th style="width:18px;text-align: start">(P)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="students" t-as="student">
                                <t t-set="present_days" t-value="0"/>
                                <tr>
                                    <td><t t-esc="student.name"/></td>
                                    <td style="text-align: center"><t t-esc="student.roll_no"/></td>
                                    <t t-foreach="dates" t-as="d">
                                        <td>
                                            <t t-set="status" t-value="attendance_dict.get(student.id, {}).get(d.strftime('%Y-%m-%d'))"/>
                                            <t t-if="status == True">
                                                <t t-set="present_days" t-value="present_days + 1"/>
                                                <span style="color:green;"><b>P</b></span>
                                            </t>
                                            <t t-elif="status == False"><span style="color:red;"><b>A</b></span></t>
                                            <t t-else="">-</t>
                                        </td>
                                    </t>
                                    <td style="text-align: center"><t t-esc="present_days"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </template>


</odoo>



