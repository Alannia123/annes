<odoo>

    <!-- 🎤 Voice To Number Button -->
    <t t-name="mis_education_attendances.VoiceToNumberButton">
        <button type="button"
                class="btn"
                t-att-class="state.isListening ? 'btn-danger' : 'btn-secondary'"
                t-on-click="toggleRecording"
                title="Voice to Number">
            <i t-att-class="state.isListening
                ? 'fa fa-microphone-slash'
                : 'fa fa-microphone'"/>
        </button>
    </t>

    <!-- 🧾 Voice To Number Field -->
    <t t-name="mis_education_attendances.VoiceToNumberField">
        <div class="d-flex align-items-center gap-1">
            <CharField t-props="props"/>
            <VoiceToNumberButton
                record="record"
                fieldName="props.name"/>
            <button type="button"
                    class="btn btn-light"
                    t-on-click="clearText"
                    title="Clear">
                <i class="fa fa-times"/>
            </button>
        </div>
    </t>

</odoo>
