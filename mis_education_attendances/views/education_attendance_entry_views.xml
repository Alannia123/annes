<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Form view of the Education attendance-->
    <record id="education_attendance_entry_view_form" model="ir.ui.view">
        <field name="name">education.attendance.entry.view.form</field>
        <field name="model">education.attendance.entry</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_attendance_done" type="object"
                            invisible="state != 'draft'"
                            class="oe_highlight" string="Done"/>
                    <button name="action_set_to_draft" type="object"
                            invisible="state == 'draft'"
                            string="Set to Draft"
                            groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin,mis_education_core.group_education_faculty"/>
                    <field name="state" readonly="1" widget="statusbar"/>
                </header>
                <sheet>
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="division_id"
                                   readonly="state == 'done'" options="{'no_create':True,'no_open':True}"/>
                            <field name="faculty_id" options="{'no_create':True,'no_open':True}"/>
                            <field name="class_id" invisible="1"/>
                            <field name="academic_year_id" readonly="1" options="{'no_create':True,'no_open':True}"/>
                        </group>
                        <group>
                            <field name="date" readonly="1" />
                            <field name="create_uid" string="Updated By" options="{'no_create':True,'no_open':True}"/>
                        </group>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <!--Tree view of the Education attendance-->
    <record id="education_attendance_entry_view_tree" model="ir.ui.view">
        <field name="name">education.attendance.entry.view.tree</field>
        <field name="model">education.attendance.entry</field>
        <field name="arch" type="xml">
            <tree>
                <field name="division_id"/>
                <field name="class_id"/>
                <field name="date"/>
                <field name="state" decoration-warning="state == 'draft'" decoration-success="state == 'done'" widget="badge" optional="show"/>
                <field name="create_uid" string="Updated By"/>
            </tree>
        </field>
    </record>

    <!--Search view of the Education attendance-->
    <record id="education_attendance_entry_view_search" model="ir.ui.view">
        <field name="name">education.attendance.entry.view.search</field>
        <field name="model">education.attendance.entry</field>
        <field name="arch" type="xml">
            <search string="Students Attendants">
                <field name="faculty_id"/>
                <field name="division_id"/>
                <filter string="Today" name="today"
                        domain="[('date','=',time.strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <filter string="Done" name="done_state"
                        domain="[('state','!=','draft')]"/>
                <separator/>
                <filter string="Current Academic Year"
                        name='current_academic_year'
                        domain="[('academic_year_id.ay_start_date', '&lt;=', context_today().strftime('%Y-%m-%d')),
                            ('academic_year_id.ay_end_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="1" string="Group By">
                    <filter string="Class" name="group_class_id"
                            context="{'group_by':'class_id'}"/>
                    <filter string="Division" name="group_division_id"
                            context="{'group_by':'division_id'}"/>
                </group>
                <filter name="group_by_faculty" string="Faculty" context="{'group_by': 'faculty_id'}"/>

            </search>
        </field>
    </record>
    <!--Menu action of the Education attendance-->
    <record id="education_attendance_entry_action" model="ir.actions.act_window">
        <field name="name">Attendance Entry</field>
        <field name="res_model">education.attendance.entry</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
        <field name="context">{'search_default_today': 1,
            'search_default_group_class_id': 1}
        </field>
    </record>



    <menuitem id="education_attendance_entry_root_menu" name=" Daily Attendance"
              sequence="10" action="education_attendance_entry_action"
              web_icon="mis_education_attendances,static/description/icon.png"/>


</odoo>
