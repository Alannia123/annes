<odoo>

    <record id="view_student_fine_log_tree" model="ir.ui.view">
    <field name="name">student.fine.log.tree</field>
    <field name="model">student.fine.log</field>
    <field name="arch" type="xml">
        <tree string="Fine Change Logs">
            <field name="student_id"/>
            <field name="academic_year_id"/>
            <field name="old_amount"/>
            <field name="new_amount"/>
            <field name="changed_by"/>
            <field name="change_date"/>
        </tree>
    </field>
</record>

<record id="view_student_fine_log_form" model="ir.ui.view">
    <field name="name">student.fine.log.form</field>
    <field name="model">student.fine.log</field>
    <field name="arch" type="xml">
        <form string="Fine Change Log">
            <sheet>
                <group>
                    <field name="student_id"/>
                    <field name="fee_line_id"/>
                    <field name="academic_year_id"/>
                </group>

                <group>
                    <field name="old_amount"/>
                    <field name="new_amount"/>
                </group>

                <group>
                    <field name="changed_by"/>
                    <field name="change_date"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

    <record id="action_student_fine_log" model="ir.actions.act_window">
    <field name="name">Fine Change Logs</field>
    <field name="res_model">student.fine.log</field>
    <field name="view_mode">tree,form</field>
</record>




</odoo>