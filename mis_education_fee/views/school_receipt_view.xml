<!-- views/school_receipt_views.xml -->
<odoo>

    <record id="view_school_receipt_tree" model="ir.ui.view">
        <field name="name">school.receipt.tree</field>
        <field name="model">school.receipt</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="student_name"/>
                <field name="student_class"/>
                <field name="session"/>
                <field name="amount"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <record id="view_school_receipt_form" model="ir.ui.view">
        <field name="name">school.receipt.form</field>
        <field name="model">school.receipt</field>
        <field name="arch" type="xml">
            <form>
                <header>
    <button name="action_confirm"
            string="Confirm"
            type="object"
            states="draft"
            class="btn-primary"/>

    <button name="%(school_receipt_print)d"
            string="Print Receipt"
            type="action"
            states="confirmed"
            class="btn-success"/>

    <field name="state" widget="statusbar"/>
</header>


                <sheet>
                    <group>
    <field name="student_name"/>
    <field name="student_class"/>
    <field name="session"/>
</group>

<group string="Fee Details">
    <field name="line_ids">
        <tree editable="bottom">
            <field name="description"/>
            <field name="amount"/>
            <field name="account_id"/>
        </tree>
    </field>
</group>

<group>
    <field name="total_amount" readonly="1"/>
    <field name="amount_words"/>
</group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- views/school_receipt_menu.xml -->
<odoo>

    <menuitem id="menu_school_receipt_root"
              name="School Receipts"
              parent="account.menu_finance"
              sequence="60"/>

    <record id="action_school_receipt" model="ir.actions.act_window">
        <field name="name">School Receipts</field>
        <field name="res_model">school.receipt</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_school_receipt"
              parent="education_fee_structure_menu_root"
              action="action_school_receipt"
              sequence="3"/>

</odoo>


</odoo>
