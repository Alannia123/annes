<odoo>


    <record id="view_application_fee_tree" model="ir.ui.view">
        <field name="name">application.fee.receipt.tree</field>
        <field name="model">application.fee.receipt</field>
        <field name="arch" type="xml">
            <tree string="Application Receipts" create="true" edit="true">
                <field name="name"/>
                <field name="student_name"/>
                <field name="class_id"/>
                <field name="amount" sum="Total" optional="show"/>
                <field name="academic_year_id"/>
                <field name="company_id" column_invisible="1"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" decoration-info="state == 'draft'" decoration-success="state == 'paid'" decoration-muted="state == 'cancel'" widget="badge"/>
            </tree>
        </field>
    </record>



    <record id="view_application_fee_form" model="ir.ui.view">
        <field name="name">application.fee.form</field>
        <field name="model">application.fee.receipt</field>
        <field name="arch" type="xml">
            <form string="Application Fee Receipt">
                <header>
                        <button name="action_pay_and_print" string="Pay &amp; Print"
                                type="object" class="btn-primary"
                               invisible="state != 'draft'"/>

                        <button name="action_print_receipt"
                                string="Print Receipt"
                                type="object" invisible="state != 'paid'"
                                class="btn-primary"/>
                    <button name="reset_to_draft"
                                string="Reset"
                                type="object" invisible="state != 'paid'"
                                class="btn-primary"/>
                    <button name="action_set_cancel"
                                string="Cancel"
                                type="object" invisible="state != 'draft'"
                                class="btn-primary"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                <sheet>
                    <div class="oe_title">
                            <h1>
                                <field name="name"  readonly="1" placeholder="Draft"/>
                            </h1>
                        </div>
                    <group>

                        <group>
                            <field name="student_name" readonly="state == 'paid'" required="1"/>
                            <field name="class_id" options="{'no_create': True, 'no_open': True}" readonly="state == 'paid'" required="1"/>
                        </group>
                        <group>
                            <field name="amount" widget="monetary"/>
                            <field name="date" readonly="1"/>
                            <field name="academic_year_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            <field name="company_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            <field name="currency_id" invisible="1" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_application_fee" model="ir.actions.act_window">
        <field name="name">Application Receipts</field>
        <field name="res_model">application.fee.receipt</field>
        <field name="view_mode">tree,form</field>
    </record>

