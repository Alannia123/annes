<!--              name="Application Receipts" action="action_application_fee" sequence="3"/>-->

    <menuitem id="menu_customer_invoices_menu_root" web_icon="mis_education_fee,static/description/invoices.png" groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin"
              name="Student Invoices" action="account.action_move_out_invoice_type" sequence="6"/>

    <menuitem id="menu_expenses_menu_root" web_icon="mis_education_fee,static/description/icon_exp.png" groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin"
              name="Expense Management" action="hr_expense.hr_expense_actions_my_all" sequence="7"/>

    <menuitem id="menu_vendor_bills_menu_root" web_icon="mis_education_fee,static/description/bills.png" groups="mis_education_core.group_education_principal,mis_education_core.group_education_office_admin"
              name="Vendor Management" action="account.action_move_in_invoice_type" sequence="8"/>

</odoo>
