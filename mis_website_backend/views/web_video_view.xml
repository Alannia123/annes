		<record id="website_video_youtube_tree" model="ir.ui.view">
			<field name="name">web.video.youtube.tree</field>
			<field name="model">web.video.youtube</field>
			<field name="arch" type="xml">
				<tree string="Photo Gallery" editable="top">
					<field name="name" />
					<field name="date" />
					<field name="school_video_url" />
					<field name="media_url" />
					<field name="user_id" options="{'no_create': True, 'no_open': True}"/>
					<field name="show_website" widget="boolean_toggle"/>
				</tree>
			</field>
		</record>


		<record id="website_video_youtube_action" model="ir.actions.act_window">
			<field name="name">Web Video</field>
			<field name="res_model">web.video.youtube</field>
<!--			<field name="context">{'search_default_state':1}</field>-->
			<field name="view_mode">tree</field>
