<odoo>


    <record id="view_certificate_form" model="ir.ui.view">
        <field name="name">mis.certificate.form</field>
        <field name="model">mis.certificate</field>
        <field name="arch" type="xml">
            <form string="Certificate">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="academic_year_id"/>
                        <field name="certificate_type"/>
                        <field name="template_background" filename="template_background_name"/>
                    </group>

                    <notebook>
                        <page string="Students">
                            <field name="student_line_ids">
                                <tree editable="bottom">
                                    <field name="student_id"/>
                                    <field name="position"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_certificate_tree" model="ir.ui.view">
        <field name="name">mis.certificate.tree</field>
        <field name="model">mis.certificate</field>
        <field name="arch" type="xml">
            <tree string="Certificate">
                <field name="name"/>
                <field name="academic_year_id"/>
            </tree>
        </field>
    </record>

    <record id="website_e_certificate_action" model="ir.actions.act_window">
        <field name="name">E Certificate</field>
        <field name="res_model">mis.certificate</field>
<!--			<field name="context">{'search_default_state':1}</field>-->
        <field name="view_mode">tree,form</field>
    </record>


</odoo>
