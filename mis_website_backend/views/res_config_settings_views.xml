<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Configure access keys    -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.amazon.s3.connector
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='integration']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box" id="amazon">
                    <div class="o_setting_left_pane">
                        <field name="is_amazon_connector"
                               string="Amazon S3 Cloud Storage"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="is_amazon_connector"/>
                        <div class="text-muted">
                            Synchronize with Amazon S3 Cloud Storage
                        </div>
                    </div>
                    <div class="o_setting_right_pane">
                        <span invisible="(is_amazon_connector == False)">
                            Access key:
                            <field name="amazon_access_key"
                                   invisible="(is_amazon_connector == False)"/>
                        </span>
                    </div>
                    <div class="o_setting_right_pane">
                        <span invisible="(is_amazon_connector == False)">
                            Secret access key:
                            <field name="amazon_secret_key" password="True"
                                   invisible="(is_amazon_connector == False)"/>
                        </span>
                    </div>
                    <div class="o_setting_right_pane">
                        <span invisible="(is_amazon_connector == False)">
                            Bucket Name:
                            <field name="amazon_bucket_name"
                                   invisible="(is_amazon_connector == False)"/>
                        </span>
                    </div>
                    <div class="o_setting_right_pane">
                        <span invisible="(is_amazon_connector == False)">
                            Region Name:
                            <field name="amazon_region_name"
                                   invisible="(is_amazon_connector == False)"/>
                        </span>
                    </div>
                </div>

                 <div class="app_settings_block" data-string="Social Media Links">
                    <h2>Social Media Links</h2>

                    <div class="row mt16 o_settings_container">

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="google_map_link"/>
                                <field name="google_map_link"/>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="facebook_link"/>
                                <div class="text-muted">Facebook page URL</div>
                                <field name="facebook_link"/>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="instagram_link"/>
                                <div class="text-muted">Instagram page URL</div>
                                <field name="instagram_link"/>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="youtube_link"/>
                                <div class="text-muted">YouTube channel URL</div>
                                <field name="youtube_link"/>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="twitter_link"/>
                                <div class="text-muted">Twitter / X page URL</div>
                                <field name="twitter_link"/>
                            </div>
                        </div>

                    </div>

                </div>
            </xpath>
        </field>
    </record>
</odoo>
