<?xml version="1.0" encoding="utf-8"?>
<odoo>


<!--    Paper Format-->
    <record id="certificate_paperformat" model="report.paperformat">
        <field name="name">Science Certificate Format</field>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
    </record>



    <record id="print_e_certificate_pdf" model="ir.actions.report">
    <field name="name">Science Certificate</field>
    <field name="model">mis.certificate</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">mis_website_backend.science_certificate_template</field>
    <field name="report_file">mis_website_backend.science_certificate_template</field>
    <field name="print_report_name">'Certificate_%s' % (object.name)</field>
    <field name="paperformat_id" ref="mis_website_backend.certificate_paperformat"/>
</record>


</odoo>
