<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-extend="web.ReportAction">
        <xpath expr="//button[@t-on-click='print']" position="replace">
            <button t-on-click="print" type="button" class="btn btn-primary" title="Download">
                <i class="fa fa-download me-1"/> Download
            </button>
        </xpath>
    </t>
</templates>
