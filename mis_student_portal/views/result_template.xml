<?xml version="1.0" encoding="utf-8"?>
<odoo>
                <template id="portal_student_result" name="Monthly Payment Tiles" >
                    <t t-call="portal.portal_layout">
                        <style>
                        table, th, td {
                            padding-left:10px;
                            padding: 2px !important;
                            border : 1.8px solid black;
                        }
                        </style>
                    <t t-if="over_due == 'over_due'">
                        <div class="alert alert-warning text-center" style="border-radius: 10px; padding: 15px; margin: 20px 0;">
                            <strong>Sorry for your inconvenience.</strong><br/>
                            Please contact the office admin for further assistance.
                        </div>
                    </t>
                        <t t-else="">
                            <div class="container mt-4">
                        <h3 class="mb-3">Student Results</h3>
                        <div>
                            <t t-set="exam_types" t-value="student._get_exams_type()"/>
                            <t t-set="aca_exams" t-value="student._get_exams_aca_class()"/>
                            <t t-set="student_aca_exam_results" t-value="student._get_exam_academic_year()"/>
                            <table width="100%" style="border: 1.5px solid black;">
                                <thead >
                                    <tr>
                                        <th name="subjects" style="background-color: #d1e0e0;" rowspan="2" class="text-center"><span>SUBJECTS</span></th>
                                        <th name="term_1"  style="background-color: #c6d9ec;" class="text-center"><span>1<sup>st</sup> UNIT</span></th>
                                        <th name="term_2" style="background-color: #d9f2e6;" colspan="3" class="text-center"><span>Half Yearly</span></th>
                                        <th name="term_3"  style="background-color: #ffddcc;" class="text-center"><span>2<sup>nd</sup> UNIT</span></th>
                                        <th name="term_3" style="background-color: #ecc6d9;" colspan="3" class="text-center"><span>Annual Exam</span></th>
                                    </tr>
                                    <tr>
<!--                                                        <th name="exam_1" class="text-center"><span>Exam</span></th>-->
<!--                                                        <th name="assign_1" class="text-center"><span>Assign</span></th>-->
                                        <th name="total_1" style="background-color: #c6d9ec;" class="text-center"><span>Total<span style="font-weight: normal;">(50)</span></span></th>
                                        <th name="exam_2" style="background-color: #d9f2e6;" class="text-center"><span>Exam<span style="font-weight: normal;">(80)</span></span></th>
                                        <th name="assign_2" style="background-color: #d9f2e6;" class="text-center"><span>Assign<span style="font-weight: normal;">(20)</span></span></th>
                                        <th name="total_2" style="background-color: #d9f2e6;" class="text-center"><span>Total<span style="font-weight: normal;">(100)</span></span></th>
                                        <th name="total_1" style="background-color: #ffddcc;" class="text-center"><span>Total<span style="font-weight: normal;">(50)</span></span></th>
                                        <th name="exam_3" style="background-color: #ecc6d9;" class="text-center"><span>Exam<span style="font-weight: normal;">(80)</span></span></th>
                                        <th name="assign_3" style="background-color: #ecc6d9;" class="text-center"><span>Assign<span style="font-weight: normal;">(20)</span></span></th>
                                        <th name="total_3" style="background-color: #ecc6d9;" class="text-center"><span>Total<span style="font-weight: normal;">(100)</span></span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="first_unit" t-value="aca_exams.filtered(lambda aca_exam: aca_exam.exam_type_id.exam_order == 'first')"/>
                                    <t t-set="half_year" t-value="aca_exams.filtered(lambda aca_exam: aca_exam.exam_type_id.exam_order == 'half')"/>
                                    <t t-set="second_unit" t-value="aca_exams.filtered(lambda aca_exam: aca_exam.exam_type_id.exam_order == 'second')"/>
                                    <t t-set="annual" t-value="aca_exams.filtered(lambda aca_exam: aca_exam.exam_type_id.exam_order == 'annual')"/>

                                    <t t-set="first_unit_result" t-value="student_aca_exam_results.filtered(lambda aca_exam_result: aca_exam_result.exam_id.id == first_unit.id)"/>
                                    <t t-set="halfly_result" t-value="student_aca_exam_results.filtered(lambda aca_exam_result: aca_exam_result.exam_id.id == half_year.id)"/>
                                    <t t-set="second_unit_result" t-value="student_aca_exam_results.filtered(lambda aca_exam_result: aca_exam_result.exam_id.id == second_unit.id)"/>
                                    <t t-set="annual_result" t-value="student_aca_exam_results.filtered(lambda aca_exam_result: aca_exam_result.exam_id.id == annual.id)"/>

                                    <t t-foreach="student.class_division_id.class_id.subject_ids" t-as="subject_line">
                                        <tr>

                                            <t t-set="fir_subject_mark" t-value="first_unit_result.subject_line_ids.filtered(lambda fir_subject: fir_subject.subject_id.id == subject_line.subject_id.id)[:1]"/>
                                            <t t-set="half_subject_mark" t-value="halfly_result.subject_line_ids.filtered(lambda half_subject: half_subject.subject_id.id == subject_line.subject_id.id)[:1]"/>
                                            <t t-set="sec_subject_mark" t-value="second_unit_result.subject_line_ids.filtered(lambda sec_subject: sec_subject.subject_id.id == subject_line.subject_id.id)[:1]"/>
                                            <t t-set="ann_subject_mark" t-value="halfly_result.subject_line_ids.filtered(lambda ann_subject: ann_subject.subject_id.id == subject_line.subject_id.id)[:1]"/>
                                            <td name="subject" style="background-color: #e0ebeb;" class="text-left"><span><t t-esc="subject_line.subject_id.name"></t></span></td>
                                            <td class="text-center">
                                                <t t-if="first_unit_result">
                                                    <t t-if="fir_subject_mark.mark_scored == 0"> -
<!--                                                        <t t-esc="int(fir_subject_mark.mark_scored)"/>-->
                                                    </t>
                                                    <t t-elif="fir_subject_mark.mark_scored &lt; fir_subject_mark.pass_mark">
                                                        <span style="color: red;"> <t t-esc="int(fir_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color: green;"> <t t-esc="int(fir_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="halfly_result">
                                                    <t t-if="half_subject_mark.exam_mark == 0" > - </t>
                                                    <t t-else=""><t t-esc="int(half_subject_mark.exam_mark)"/></t>
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="halfly_result">
                                                    <t t-if="half_subject_mark.assign_mark == 0" > - </t>
                                                    <t t-else=""><t t-esc="int(half_subject_mark.assign_mark)"/></t>
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="halfly_result">
                                                    <t t-if="half_subject_mark.mark_scored == 0"> -
<!--                                                        <t t-esc="int(half_subject_mark.mark_scored)"/>-->
                                                    </t>
                                                    <t t-elif="half_subject_mark.mark_scored &lt; half_subject_mark.pass_mark">
                                                        <span style="color: red;"> <t t-esc="int(half_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color: green;"> <t t-esc="int(half_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                </t>
                                                <t t-else=""></t>
                                            </td><td class="text-center">
                                                <t t-if="second_unit_result">
                                                    <t t-if="sec_subject_mark.mark_scored == 0"> -
<!--                                                        <t t-esc="int(sec_subject_mark.mark_scored)"/>-->
                                                    </t>
                                                    <t t-elif="sec_subject_mark.mark_scored &lt; sec_subject_mark.pass_mark">
                                                        <span style="color: red;"> <t t-esc="int(sec_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color: green;"> <t t-esc="int(sec_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="annual_result">
                                                    <t t-if="annual_result.exam_mark == 0" > - </t>
                                                    <t t-else=""><t t-esc="int(annual_result.exam_mark)"/></t>
<!--                                                    <t t-esc="int(ann_subject_mark.exam_mark)"/>-->
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="annual_result">
                                                    <t t-if="annual_result.assign_mark == 0" > - </t>
                                                    <t t-else=""><t t-esc="int(annual_result.assign_mark)"/></t>
<!--                                                    <t t-esc="int(ann_subject_mark.assign_mark)"/>-->
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="annual_result">
                                                    <t t-if="ann_subject_mark.mark_scored == 0"> -
<!--                                                        <t t-esc="int(ann_subject_mark.mark_scored)"/>-->
                                                    </t>
                                                    <t t-elif="ann_subject_mark.mark_scored &lt; ann_subject_mark.pass_mark">
                                                        <span style="color: red;"> <t t-esc="int(ann_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="color: green;"> <t t-esc="int(ann_subject_mark.mark_scored)"/></span>
                                                    </t>
                                                </t>
                                                <t t-else=""></t>
                                            </td>
                                        </tr>
                                    </t>
<!--                                                    ADD EMpty lines-->
                                    <t t-foreach="range(max(14-len(student.class_division_id.class_id.subject_ids),0))" t-as="ln">
                                        <tr>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td style="color: #ffffff;" >SKU</td>
                                        </tr>
                                    </t>
                                    <tr>
                                        <td class="text-right" style="background-color: #e0ebeb;"><span><b>TOTAL</b></span></td>
                                        <td class="text-center"><t t-esc="int(first_unit_result.total_mark_scored)"/></td>
                                        <td colspan="2" style="color: #ffffff;"></td>
                                        <td class="text-center"><t t-esc="int(halfly_result.total_mark_scored)"/></td>
                                        <td class="text-center"><t t-esc="int(second_unit_result.total_mark_scored)"/></td>
                                        <td colspan="2" style="color: #ffffff;"></td>
                                        <td class="text-center"><t t-esc="int(annual_result.total_mark_scored)"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right" style="background-color: #e0ebeb;"><span><b>PERCENTAGE</b></span></td>
                                        <td class="text-center"><t t-esc="round((first_unit_result.total_mark_percentage), 2)"/></td>
                                        <td colspan="2" style="color: #ffffff;"></td>
                                        <td class="text-center"><t t-esc="round((halfly_result.total_mark_percentage), 2)"/></td>
                                        <td class="text-center"><t t-esc="round((second_unit_result.total_mark_percentage), 2)"/></td>
                                        <td colspan="2" style="color: #ffffff;"></td>
                                        <td class="text-center"><t t-esc="round((annual_result.total_mark_percentage), 2)"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right" style="background-color: #e0ebeb;"><span><b>GRADE</b></span></td>
                                        <td class="text-center"><b><t t-esc="first_unit_result.grade"/></b></td>
                                        <td class="text-center" colspan="3" ><b><t t-esc="halfly_result.grade"/></b></td>
                                        <td class="text-center" ><b><t t-esc="second_unit_result.grade"/></b></td>
                                        <td class="text-center" colspan="3" ><b><t t-esc="annual_result.grade"/></b></td>
                                    </tr>
                                    <tr>
                                        <td class="text-right" style="background-color: #e0ebeb;"><span><b>ATTENDANCE</b></span></td>
                                        <td style="color: #ffffff;"></td>
                                        <td colspan="3" style="color: #ffffff;"></td>
                                        <td style="color: #ffffff;"></td>
                                        <td colspan="3" style="color: #ffffff;"></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                        </t>
                    </t>
            </template>



</odoo>