<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web.BurgerMenu" t-inherit="web.BurgerMenu" t-inherit-mode="primary">
        <xpath expr="//button[hasclass('o_mobile_menu_toggle')]" position="replace">
            <button
        class="o_mobile_menu_toggle o_nav_entry o-no-caret d-md-none border-0 pe-3"
        title="Toggle menu" aria-label="Toggle menu"
        t-on-click="_openBurger">
        <i class="fa fa-bars"/>
    </button>
        </xpath>
    </t>
</templates>
