                <img src="/mis_website/static/src/img/appl.png" />
            </span>

            <style>
                /* ====== General Look ====== */
                body {
                    font-family: 'Poppins', sans-serif;
                }
                .glow-background {
                    background: #ffffffcc;
                    border-radius: 10px;
                    padding: 30px;
                    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
                    animation: fadeIn 1s ease-in;
                }
                @keyframes fadeIn {
                    from { opacity: 0; transform: translateY(10px); }
                    to { opacity: 1; transform: translateY(0); }
                }

                /* ====== Title Styling ====== */
                .page-title {
                    font-family: "Times New Roman", serif;
                    color: #1d3557;
                    text-align: center;
                    font-size: 32px;
                    text-shadow: 1px 2px 3px rgba(0,0,0,0.3);
                    letter-spacing: 1px;
                    margin-bottom: 10px;
                }
                .section-subtitle {
                    text-align: center;
                    color: #555;
                    font-size: 18px;
                    margin-bottom: 20px;
                }

                /* ====== Card Styling ====== */
                .card {
                    background: linear-gradient(180deg, #f9fafc, #ffffff);
                    border-radius: 15px;
                    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
                    padding: 25px;
                    transition: all 0.3s ease;
                }
                .card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
                }

                /* ====== Labels  Inputs ====== */
                label span {
                    font-weight: 600;
                    color: #1d3557;
                }
                input[type="text"], input[type="date"], select {
                    border: 1px solid #ccc;
                    border-radius: 8px;
                    padding: 10px;
                    width: 100%;
                    font-size: 15px;
                    transition: 0.3s;
                }
                input:focus, select:focus {
                    border-color: #1d3557;
                    box-shadow: 0 0 6px rgba(29,53,87,0.3);
                    outline: none;
                }

                /* ====== Animated Typing Heading ====== */
                .typing-text {
                    font-family: monospace;
                    font-size: 24px;
                    white-space: nowrap;
                    overflow: hidden;
                    border-right: 3px solid #1d3557;
                    width: 40ch;
                    animation: typing 3s steps(40), blink 0.7s step-end infinite;
                    color: #1d3557;
                    text-align: center;
                    margin: 15px auto;
                    font-weight: 600;
                }
                @keyframes typing {
                    from { width: 0; }
                    to { width: 40ch; }
                }
                @keyframes blink {
                    50% { border-color: transparent; }
                }

                /* ====== Button Styling ====== */
                .btn-primary {
                    background: linear-gradient(90deg, #1d3557, #457b9d);
                    border: none;
                    color: #fff;
                    font-size: 18px;
                    font-weight: 600;
                    border-radius: 8px;
                    box-shadow: 0 3px 8px rgba(0,0,0,0.2);
                    transition: all 0.3s ease;
                }
                .btn-primary:hover {
                    background: linear-gradient(90deg, #457b9d, #1d3557);
                    transform: scale(1.05);
                }

                /* ====== Numbered Points Styling ====== */
                .guidelines {
                    background: #f8fafc;
                    border-left: 4px solid #1d3557;
                    padding: 10px 15px;
                    border-radius: 5px;
                    margin-bottom: 15px;
                    color: #333;
                }

                /* ====== Smooth Fade for Parallax Overlay ====== */
                .s_parallax_bg img {
                    filter: brightness(0.7);
                }
            </style>

