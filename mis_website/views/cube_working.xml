<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="mis_home_page" name="MIS Website Page (Soft Glow)">
    <t t-call="website.layout">
      <div id="wrap" class="oe_structure o_cc3 o_colored_level">

        <!-- ================= Banner ================= -->
        <t t-if="banner">
          <div class="mis-banner-strip">
            <div class="hov_hi" style="background:linear-gradient(180deg,#B33A3A 0%,#004AAD 100%);color:#fff;font-weight:700;">
              <marquee onmouseover="this.stop();" onmouseout="this.start();" style="padding:6px 0;font-size:17px;">
                <t t-out="banner.info"/>
              </marquee>
            </div>
          </div>
        </t>

        <!-- ============ Hidden JSON (Dynamic Cube Data) ============ -->
        <t t-if="random_images">
          <div id="cube_json_data"
               t-att-data-json="random_images"
               style="display:none;"></div>
        </t>

        <!-- =================== MAIN 3D CUBE SLIDER =================== -->
        <section class="s_school_cube_box py-5" data-name="3D Cube Box Slider (Dynamic)">
          <div class="container text-center">

            <!-- 🌟 Hero Heading for School -->
            <div class="cube-hero-text mb-4">
              <h4 class="hero-education-title">
                Change the world with <b>Education</b> and <b>Carve</b> your Child's Future with <b>MIS</b>.
              </h4>
              <p class="hero-education-subtitle">
                To Sail in the Ocean of Wisdom...
              </p>
            </div>

            <h2 class="cube-heading mb-4">
              <i class="fa-solid fa-university"></i> CAMPUS HIGHLIGHTS
            </h2>

            <div class="cube-scene">
              <div class="cube" id="multiCube">
                <div class="cube-face front"></div>
                <div class="cube-face right"></div>
                <div class="cube-face back"></div>
                <div class="cube-face left"></div>
              </div>

              <div class="cube-controls">
                <button class="cube-prev"><i class="fa fa-chevron-left"></i></button>
                <button class="cube-next"><i class="fa fa-chevron-right"></i></button>
              </div>
            </div>
          </div>

          <!-- ============= CSS FOR THE CUBE + HEADING ============= -->
          <style>
            /* Hero text above cube */
            .cube-hero-text {
              max-width: 900px;
              margin: 0 auto 10px auto;
              position: relative;
              z-index: 2; /* ensure always above background shapes */
            }

            .hero-education-title {
              font-size: 28px;
              font-weight: 800;
              line-height: 1.3;
              text-align: center;
              background: linear-gradient(90deg,#ff66b2,#ffd700,#66ccff);
              -webkit-background-clip: text;
              -webkit-text-fill-color: transparent;
              text-shadow: 0 0 12px rgba(0,0,0,0.25);
              margin-bottom: 8px;
            }
            .hero-education-title b {
              color:#ff3399;
              -webkit-text-fill-color:#ff3399;
            }

            .hero-education-subtitle {
              font-size: 16px;
              text-align: center;
              color: #f5f7ff;
              text-shadow: 0 0 6px rgba(0,0,0,0.35);
              letter-spacing: 0.08em;
              text-transform: uppercase;
            }

            .cube-heading {
              font-size: 32px;
              font-weight: 800;
              text-transform: uppercase;
              color: #00bfff;
              text-shadow: 0 0 10px rgba(0,191,255,0.5);
              letter-spacing: 0.12em;
            }

            .cube-scene {
              width: 90%;
              max-width: 700px;
              height: 360px;
              margin: 10px auto 0 auto;
              perspective: 1200px;
              position: relative;
            }

            .cube {
              width: 100%;
              height: 100%;
              position: relative;
              transform-style: preserve-3d;
              transition: transform 1.3s ease-in-out;
            }

            .cube-face {
              position: absolute;
              width: 100%;
              height: 100%;
              border-radius: 20px;
              background-size: cover;
              background-position: center;
              box-shadow: 0 5px 20px rgba(0,0,0,0.25);
              backface-visibility: hidden;
              overflow: hidden;
            }

            .cube-face.front  { transform: rotateY(0deg) translateZ(350px); }
            .cube-face.right  { transform: rotateY(-90deg) translateZ(350px); }
            .cube-face.back   { transform: rotateY(-180deg) translateZ(350px); }
            .cube-face.left   { transform: rotateY(90deg) translateZ(350px); }

            /* ======== Caption Styling ======== */
            .cube-caption {
              position: absolute;
              bottom: 0;
              left: 0;
              width: 100%;
              padding: 18px 22px;
              background: linear-gradient(180deg, rgba(0,0,0,0.1), rgba(0,0,0,0.7));
              color: #fff;
              border-radius: 0 0 20px 20px;
            }

            .cube-title {
              font-size: 22px;
              font-weight: 700;
              color: #00eaff;
              margin: 0;
              text-shadow: 0 0 6px rgba(0,0,0,0.4);
            }

            .cube-desc {
              font-size: 14px;
              margin-top: 4px;
              color: #e6faff;
            }

            /* ===== Controls ===== */
            .cube-controls {
              position: absolute;
              top: 50%;
              width: 100%;
              display: flex;
              justify-content: space-between;
              transform: translateY(-50%);
            }

            .cube-controls button {
              background: rgba(0,0,0,0.45);
              border: 2px solid rgba(255,255,255,0.3);
              color: #fff;
              font-size: 22px;
              padding: 8px 12px;
              border-radius: 50%;
              transition: 0.3s ease;
            }

            .cube-controls button:hover {
              background: linear-gradient(135deg, #00bfff, #ff007f);
              box-shadow: 0 0 15px rgba(0,191,255,0.6);
              transform: scale(1.15);
            }

            @media(max-width:768px){
              .hero-education-title {
                font-size: 20px;
              }
              .hero-education-subtitle {
                font-size: 13px;
              }
              .cube-heading {
                font-size: 24px;
              }
              .cube-scene {
                height: 280px;
              }
              .cube-face.front,
              .cube-face.right,
              .cube-face.back,
              .cube-face.left {
                transform: translateZ(250px);
              }
            }
          </style>

          <!-- ============= JS FOR THE CUBE ============= -->
          <script type="text/javascript">
          <![CDATA[
          document.addEventListener("DOMContentLoaded", function () {

            const jsonHolder = document.getElementById("cube_json_data");
            if (!jsonHolder) return;

            let s3Images = [];
            try {
              s3Images = JSON.parse(jsonHolder.dataset.json);
            } catch (e) {
              console.error("❌ Invalid JSON", e);
              return;
            }

            const cube = document.getElementById("multiCube");
            if (!cube || !s3Images.length) return;

            const faces = cube.querySelectorAll(".cube-face");
            let index = 0;
            let rotation = 0;

            function updateFaces() {
              faces.forEach((face, i) => {
                const data = s3Images[(index + i) % s3Images.length];

                face.style.backgroundImage = "url('" + data.url + "')";

                face.innerHTML =
                  '<div class="cube-caption">' +
                    '<h3 class="cube-title">' + (data.event_name || "School Event") + '</h3>' +
                    '<p class="cube-desc">' + (data.remarks || "") + '</p>' +
                  '</div>';
              });
            }

            updateFaces();

            function rotateCube(dir = 1) {
              rotation += dir * 90;
              cube.style.transform = "rotateY(" + rotation + "deg)";
              index = (index + dir + s3Images.length) % s3Images.length;
              setTimeout(updateFaces, 600);
            }

            document.querySelector(".cube-next")?.addEventListener("click", () => rotateCube(1));
            document.querySelector(".cube-prev")?.addEventListener("click", () => rotateCube(-1));

            let auto = setInterval(() => rotateCube(1), 5000);
            cube.addEventListener("mouseenter", () => clearInterval(auto));
            cube.addEventListener("mouseleave", () => auto = setInterval(() => rotateCube(1), 5000));

          });
          ]]>
          </script>

        </section>

      </div>
    </t>
  </template>
</odoo>
