<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="app_release_temp" name="School App Download (Animated)">
        <t t-call="website.layout">
            <style>
                body {
                    background: linear-gradient(135deg, #f6f9ff 0%, #eef4ff 100%);
                    animation: gradientShift 12s ease infinite alternate;
                    background-size: 200% 200%;
                }

                @keyframes gradientShift {
                    0% { background-position: 0% 50%; }
                    100% { background-position: 100% 50%; }
                }

                .app-section {
                    width: 100%;
                    max-width: 1200px;
                    margin: 60px auto 100px auto;
                    background: rgba(255, 255, 255, 0.95);
                    border-radius: 24px;
                    padding: 60px 80px;
                    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.15);
                    text-align: center;
                    font-family: "Poppins", sans-serif;
                    animation: fadeInUp 1.2s ease;
                }

                @keyframes fadeInUp {
                    0% { opacity: 0; transform: translateY(40px); }
                    100% { opacity: 1; transform: translateY(0); }
                }

                h2 {
                    color: #002e7a;
                    font-size: 42px;
                    font-weight: 800;
                    margin-bottom: 20px;
                }

                p {
                    color: #333;
                    font-size: 20px;
                    line-height: 1.8;
                    max-width: 900px;
                    margin: 0 auto;
                }

                .store-badge {
                    margin: 40px 0 30px 0;
                }

                .store-badge img {
                    height: 90px;
                    transition: transform 0.4s ease, box-shadow 0.3s ease;
                }

                .store-badge img:hover {
                    transform: scale(1.08);
                    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
                }

                .apk-download {
                    margin: 50px auto;
                    padding: 40px;
                    max-width: 600px;
                    background: #ffffff;
                    border-radius: 20px;
                    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
                    animation: fadeInUp 1.4s ease;
                }

                .apk-download p {
                    font-size: 18px;
                    margin-bottom: 15px;
                }

                .apk-download img {
                    margin: 20px 0;
                    border-radius: 15px;
                    width: 280px;
                    transition: transform 0.4s ease, box-shadow 0.3s ease;
                    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
                }

                .apk-download img:hover {
                    transform: scale(1.05);
                    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
                }

                .btn-primary {
                    background: linear-gradient(90deg, #0048ba, #007bff);
                    border: none;
                    padding: 14px 36px;
                    font-size: 18px;
                    border-radius: 10px;
                    color: #fff;
                    font-weight: 600;
                    text-decoration: none;
                    transition: all 0.3s ease;
                    box-shadow: 0 4px 10px rgba(0, 64, 160, 0.3);
                }

                .btn-primary:hover {
                    background: linear-gradient(90deg, #003580, #005fd8);
                    transform: translateY(-3px) scale(1.05);
                    box-shadow: 0 6px 20px rgba(0, 64, 160, 0.4);
                }

                h3 {
                    color: #002e7a;
                    font-weight: 700;
                    font-size: 30px;
                    margin-top: 70px;
                    animation: fadeInUp 1.6s ease;
                }

                .app-screenshots {
                    display: flex;
                    justify-content: center;
                    gap: 35px;
                    flex-wrap: wrap;
                    margin-top: 35px;
                }

                .app-screenshots img {
                    width: 250px;
                    border-radius: 20px;
                    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.25);
                    transition: transform 0.4s ease, box-shadow 0.3s ease;
                }

                .app-screenshots img:hover {
                    transform: translateY(-8px) scale(1.03);
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
                }

                footer {
                    margin-top: 70px;
                    font-size: 16px;
                    color: #555;
                }

                @media (max-width: 768px) {
                    .app-section {
                        padding: 40px 20px;
                    }
                    h2 { font-size: 32px; }
                    p { font-size: 17px; }
                    .app-screenshots img { width: 180px; }
                }
            </style>

            <div class="app-section">
                <h2>📱 Download School App</h2>
                <p>
                    Experience our smart and seamless <b>School Management App</b>.
                    Stay connected with attendance, homework, notices, and updates — anytime, anywhere!
                </p>

                <div class="store-badge">
                    <a href="https://play.google.com/store/apps/details?id=mis.management&amp;hl=en" target="_blank">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg"
                             alt="Get it on Google Play"/>
                    </a>
                </div>

                <div class="apk-download">
                    <p>⚡ <b>Your device not supported?</b> No problem!</p>
                    <p>Scan the QR code or click below to download the APK directly:</p>
                    <img src="/mis_website/static/apk/mis_apk.png" alt="QR Code"/>
                    <br/>
                    <a href="/download/mis-app" class="btn btn-primary">
                        Download APK
                    </a>

                </div>

                <h3>📸 App Screenshots</h3>
                <div class="app-screenshots">
                    <img src="/mis_website/static/src/img/splash.jpeg" alt="Splash Screen"/>
                    <img src="/mis_website/static/src/img/screen_login.jpeg" alt="Login Screen"/>
                    <img src="/mis_website/static/src/img/screen_dashboard.jpeg" alt="Dashboard Screen"/>
                    <img src="/mis_website/static/src/img/menu.jpeg" alt="Modules Screen"/>
                </div>

                <footer>
                    <p>© 2025 St.Anne's School • Powered by <b>Alanniainfotechz</b></p>
                </footer>
            </div>
        </t>
    </template>
</odoo>
